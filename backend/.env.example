PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/orca?retryWrites=true&w=majority
JWT_SECRET=supersecretjwtkey
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=1
